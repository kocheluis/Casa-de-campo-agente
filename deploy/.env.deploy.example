# Copia este archivo a ".env" DENTRO de la carpeta deploy/ (en el VPS) y rellena los
# valores. docker compose lee automáticamente el archivo .env de esta carpeta.
# NUNCA subas el .env real a git (ya está ignorado).

# Tu dominio (sin https ni www). Ej: casadecampo.app
DOMAIN=tudominio.com

# --- PostgreSQL (inventa una contraseña fuerte) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CAMBIA_esta_clave_fuerte

# --- Redis (inventa otra contraseña) ---
REDIS_PASSWORD=CAMBIA_esta_otra_clave

# --- n8n: clave de cifrado de credenciales ---
# Genera una con:  openssl rand -hex 24
N8N_ENCRYPTION_KEY=CAMBIA_pega_aqui_lo_generado

# --- Chatwoot: clave secreta de Rails ---
# Genera una con:  openssl rand -hex 64
CHATWOOT_SECRET_KEY_BASE=CAMBIA_pega_aqui_lo_generado
