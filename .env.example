# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit real secrets.

# --- LLM (el chatbot es agnostico via LiteLLM) ---
# Elige el proveedor y modelo: solo necesitas la API key del que uses.
#   anthropic + claude-haiku-4-5-20251001   (~$1-3/mes en este caso, recomendado)
#   gemini    + gemini-2.5-flash             (plan gratis 1500 req/dia)
#   deepseek  + deepseek-chat                 (~10x mas barato que Claude)
#   openai    + gpt-4o-mini                   (mas barato que Claude pero requiere saldo)
LLM_PROVIDER=anthropic
LLM_MODEL=claude-haiku-4-5-20251001

# Pega SOLO la key del proveedor que elegiste arriba (las otras pueden quedar vacias).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=

# --- Meta (WhatsApp Cloud API + Instagram/Messenger Graph API) ---
# Se obtienen en developers.facebook.com tras verificar el negocio con el RUC.
META_ACCESS_TOKEN=
META_PHONE_NUMBER_ID=
META_VERIFY_TOKEN=
# Versión de la Graph API (ej. v21.0)
META_GRAPH_VERSION=v21.0
# Número del dueño (formato internacional sin '+') para avisos de handoff.
OWNER_WHATSAPP=

# --- Base de datos (NocoDB autoalojado en el VPS — elección del proyecto) ---
# Se eligió NocoDB sobre Baserow: Calendario gratis + API con tokens en self-hosted.
# DB_API_URL = base de la API (no la URL de una tabla específica).
# Ejemplo local: http://localhost:8080
# Ejemplo VPS:   https://db.TUDOMINIO
DB_API_URL=
DB_API_TOKEN=
# DB_TYPE: nocodb (por defecto) | baserow
DB_TYPE=nocodb
# IDs de tabla (los rellena automáticamente tools/setup_nocodb.py)
TABLE_ID_CLIENTES=
TABLE_ID_RESERVAS=
TABLE_ID_INVENTARIO=
TABLE_ID_CONVERSACIONES=

# --- Chatwoot (bandeja omnicanal + handoff, autoalojado en el VPS) ---
# n8n devuelve las respuestas a la conversación en Chatwoot vía su API.
CHATWOOT_BASE_URL=
CHATWOOT_API_TOKEN=
CHATWOOT_ACCOUNT_ID=

# --- API de video por plantillas (Fase 3) ---
# Elegir una: JSON2Video (plan gratis más generoso) o Creatomate (editor visual).
VIDEO_API_PROVIDER=json2video
VIDEO_API_KEY=

# --- Google APIs (Sheets, Slides, Drive) ---
# OAuth client downloaded from Google Cloud Console -> credentials.json
# token.json is generated on first auth run.
GOOGLE_CREDENTIALS_PATH=credentials.json
GOOGLE_TOKEN_PATH=token.json

# --- Other service credentials ---
# Add keys here as workflows require them, e.g.:
# SLACK_BOT_TOKEN=
# SCRAPER_API_KEY=
